rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to verify if user is a member of the chat
    function isChatMember(chatId) {
      return isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members);
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'status'])
        && data.keys().size() <= 7
        && data.uid == request.auth.uid
        && data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 50
        && data.email is string && data.email.size() <= 100
        && data.status in ['online', 'offline'];
    }

    function isValidChat(data) {
      return data.keys().hasAll(['id', 'isGroup', 'members', 'createdAt'])
        && data.keys().size() <= 7
        && data.id is string
        && data.isGroup is bool
        && data.members is list
        && data.members.size() >= 1 && data.members.size() <= 100
        && (request.auth.uid in data.members);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'senderId', 'senderName', 'timestamp'])
        && data.keys().size() <= 9
        && data.id is string
        && data.senderId == request.auth.uid
        && data.senderName is string && data.senderName.size() >= 1
        && (data.text == null || (data.text is string && data.text.size() <= 5000))
        && (data.fileUrl == null || data.fileUrl is string)
        && (data.fileName == null || data.fileName is string)
        && (data.fileType == null || data.fileType is string);
    }

    // Match patterns
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.members);
      // Let any authenticated user create a chat, but it must be valid and they must be a member
      allow create: if isAuthenticated() && isValidId(chatId) && isValidChat(request.resource.data);
      // For updates, they must be a member, and the updated chat must be valid
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.members) && isValidChat(request.resource.data);
      allow delete: if false;
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isChatMember(chatId);
      allow create: if isChatMember(chatId) && isValidId(messageId) && isValidMessage(request.resource.data);
      allow update, delete: if false; // Messages are immutable in our app
    }
  }
}
